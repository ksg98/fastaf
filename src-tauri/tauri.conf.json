{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastAF",
  "version": "0.0.4",
  "identifier": "com.fastaf.ide",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FastAF",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 580,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyN0Y4MDU4RUE5QjIwNDYKUldSR0lKdnFXSUIvZ2haWlBPYkY4djQ4QjRhdktyQ1ZmWFRueXpVdFZPZmxRSERmM2oveWZ6WWgK",
      "endpoints": [
        "https://github.com/ksg98/fastaf/releases/latest/download/latest.json"
      ]
    }
  }
}
