{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:window:allow-hide",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    "dialog:default",
    "notification:default"
  ]
}
